# ═══════════════════════════════════════════════════════════════════════
# BottleVision — .gitignore
# Only ship: app.py, best.pt, requirements.txt, README.md, .gitignore
# ═══════════════════════════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# ── IDE / Editor ──
.qoder/
.vscode/
.idea/
*.swp
*.swo
*~

# ── Old / reference scripts (not part of final release) ──
claude_final.py
calibrate_liquid_level.py
bottle_inspector.py
bottle_inference_variations.py
bottle_yolo_inspector.py
bottle_yolo_inspector_merged.py
bottle_yolo_inspector_merged_backup.py
variation_generator.py
variations_creator.py
config.py
main.py

# ── Old documentation (replaced by README.md) ──
DETECTION_MERGING_GUIDE.md

# ── Videos / images (too large for git, users bring their own) ──
*.mp4
*.avi
*.mkv
*.mov
*.wmv
*.jpg
*.jpeg
*.png
*.bmp
*.gif

# ── Archive / zip ──
*.zip
*.tar.gz
*.rar

# ── Subdirectories with dev artifacts ──
claude_final/
black_liquid_variations/
variations/
debug/

sprite_vision/

# ── Model weights (large binary — users download separately) ──
